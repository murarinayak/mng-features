{
  "name": "mng-features",
  "version": "22.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port=4300",
    "build": "npm run build:lib",
    "build:lib": "ng build mng-features",
    "build:demo": "ng build demo",
    "publish": "cd dist/mng-features && npm publish",
    "bp": "npm run build && npm run publish",
    "pack": "cd dist/mng-features && npm pack",
    "watch": "ng build --watch --configuration development",
    "copy:themes": "cp -r ./node_modules/@angular/material/prebuilt-themes/* projects/mng-features/assets/themes/",
    "test": "ng test"
  },
  "private": false,
  "dependencies": {
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/material": "22.0.5",
    "@angular/platform-browser": "22.0.7",
    "@angular/router": "22.0.7",
    "firebase": "12.16.0",
    "ngx-quill": "31.0.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@types/jasmine": "5.1.13",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "5.13.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "ng-packagr": "22.0.1",
    "typescript": "6.0.3",
    "vitest": "^4.0.8"
  },
